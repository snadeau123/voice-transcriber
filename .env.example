# Groq API Key (required)
GROQ_API_KEY=your_groq_api_key_here

# Whisper model for transcription (optional)
WHISPER_MODEL_GROQ=whisper-large-v3-turbo

# LLM model for text cleanup (optional)
GROQ_MODEL=openai/gpt-oss-120b

# Deepgram (optional - enables live streaming transcription)
# If set, transcription happens in real-time while recording.
# If not set, falls back to Whisper batch transcription after recording stops.
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
